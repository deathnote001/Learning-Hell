[
  {
    "id": "p001",
    "title": "观沧海",
    "author": "曹操",
    "dynasty": "东汉",
    "grade": "初一上",
    "lines": [
      "东临碣石，以观沧海。",
      "水何澹澹，山岛竦峙。",
      "树木丛生，百草丰茂。",
      "秋风萧瑟，洪波涌起。",
      "日月之行，若出其中；",
      "星汉灿烂，若出其里。",
      "幸甚至哉，歌以咏志。"
    ]
  },
  {
    "id": "p002",
    "title": "次北固山下",
    "author": "王湾",
    "dynasty": "唐",
    "grade": "初一上",
    "lines": [
      "客路青山外，行舟绿水前。",
      "潮平两岸阔，风正一帆悬。",
      "海日生残夜，江春入旧年。",
      "乡书何处达？归雁洛阳边。"
    ]
  },
  {
    "id": "p003",
    "title": "天净沙·秋思",
    "author": "马致远",
    "dynasty": "元",
    "grade": "初一上",
    "lines": [
      "枯藤老树昏鸦，",
      "小桥流水人家，",
      "古道西风瘦马。",
      "夕阳西下，断肠人在天涯。"
    ]
  },
  {
    "id": "p004",
    "title": "闻王昌龄左迁龙标遥有此寄",
    "author": "李白",
    "dynasty": "唐",
    "grade": "初一上",
    "lines": [
      "杨花落尽子规啼，",
      "闻道龙标过五溪。",
      "我寄愁心与明月，",
      "随风直到夜郎西。"
    ]
  },
  {
    "id": "p005",
    "title": "峨眉山月歌",
    "author": "李白",
    "dynasty": "唐",
    "grade": "初一上",
    "lines": [
      "峨眉山月半轮秋，",
      "影入平羌江水流。",
      "夜发清溪向三峡，",
      "思君不见下渝州。"
    ]
  },
  {
    "id": "p006",
    "title": "江南逢李龟年",
    "author": "杜甫",
    "dynasty": "唐",
    "grade": "初一上",
    "lines": [
      "岐王宅里寻常见，",
      "崔九堂前几度闻。",
      "正是江南好风景，",
      "落花时节又逢君。"
    ]
  },
  {
    "id": "p007",
    "title": "行军九日思长安故园",
    "author": "岑参",
    "dynasty": "唐",
    "grade": "初一上",
    "lines": [
      "强欲登高去，",
      "无人送酒来。",
      "遥怜故园菊，",
      "应傍战场开。"
    ]
  },
  {
    "id": "p008",
    "title": "夜上受降城闻笛",
    "author": "李益",
    "dynasty": "唐",
    "grade": "初一上",
    "lines": [
      "回乐烽前沙似雪，",
      "受降城外月如霜。",
      "不知何处吹芦管，",
      "一夜征人尽望乡。"
    ]
  }
]
